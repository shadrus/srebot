ignore_rules:
  - name: "Ignore Watchdog alerts in all clusters"
    condition:
      labels:
        alertname: "Watchdog"

  - name: "Ignore development alerts by cluster OR namespace"
    condition:
      any:
        - labels:
            cluster: "dev-cluster"
        - labels:
            namespace: "test-env"

  - name: "Ignore complex rule (AND example)"
    condition:
      all:
        - labels:
            severity: "info"
        - labels:
            job: "backup-job"
