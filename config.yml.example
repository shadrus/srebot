# ==============================================================================
# AI Health Bot Configuration Settings
# ==============================================================================

# Telegram
# Note: These can also be set via .env (TELEGRAM_BOT_TOKEN, TELEGRAM_CHANNEL_ID)
telegram_bot_token: "your_bot_token_here"
telegram_channel_id: -1001234567890

# SaaS Control Plane
saas_agent_token: "tok_your_token_here"
saas_ws_url: "ws://management.srebot.com/api/v1/agent/connect"
llm_response_language: "English"

# Redis — alert deduplication state
redis_url: "redis://redis:6379/0"
# How long (seconds) to remember a firing alert fingerprint
alert_fingerprint_ttl: 86400

# General
log_level: "INFO"
dry_run: false

mcp_servers:
  # ─────────────────────────────────────────────────────────────────────────────
  # Prometheus MCP Server
  # https://github.com/pab1it0/prometheus-mcp-server
  # ─────────────────────────────────────────────────────────────────────────────
  yandex-production-prometheus:
    command: "uvx"
    args:
      - "prometheus-mcp-server"
    env:
      PROMETHEUS_URL: "http://prometheus-prod.example.com:9090"
      # PROMETHEUS_USERNAME: "admin"
      # PROMETHEUS_PASSWORD: "secret"

  # ─────────────────────────────────────────────────────────────────────────────
  # Elasticsearch MCP Server (official, by Elastic)
  # https://github.com/elastic/mcp-server-elasticsearch
  # Install: npm install -g @elastic/mcp-server-elasticsearch
  # ─────────────────────────────────────────────────────────────────────────────
  yandex-production-elasticsearch:
    command: "npx"
    args:
      - "-y"
      - "@elastic/mcp-server-elasticsearch"
    # Limit this MCP server so it is ONLY used for alerts from the 'prod' cluster
    condition:
      labels:
        cluster: "prod"
    # read_only: true filters out write-capable tools (create, delete, bulk, etc.)
    # Recommended when ES has no auth.
    read_only: true
    env:
      ES_URL: "https://elasticsearch-prod.example.com:9200"
      # ES_API_KEY: "your-api-key-here"
      # ES_USERNAME: "elastic"
      # ES_PASSWORD: "changeme"
      # ES_SSL_SKIP_VERIFY: "true"

# ─────────────────────────────────────────────────────────────────────────────
# Alert ignore rules
# Alerts matching any of these rules will be silently dropped.
# ─────────────────────────────────────────────────────────────────────────────
ignore_rules:
  - name: "Ignore Watchdog alerts in all clusters"
    condition:
      labels:
        alertname: "Watchdog"

  - name: "Ignore development alerts by cluster OR namespace"
    condition:
      any:
        - labels:
            cluster: "dev-cluster"
        - labels:
            namespace: "test-env"

  # - name: "Ignore everything except target cluster (run only for this cluster)"
  #   condition:
  #     not_labels:
  #       cluster: "target-cluster"
