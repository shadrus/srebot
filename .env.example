# Telegram Bot
TELEGRAM_BOT_TOKEN=your_bot_token_here
# Channel/group ID where Alertmanager sends notifications (negative for groups/channels)
TELEGRAM_CHANNEL_ID=-1001234567890

# LLM — OpenAI-compatible API (works with OpenAI, Azure, LM Studio, vLLM, etc.)
LLM_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=sk-...
LLM_MODEL=gpt-4o

# Language for the LLM response (English, Russian, etc.)
LLM_RESPONSE_LANGUAGE=English


# Redis — alert deduplication state
REDIS_URL=redis://localhost:6379/0

# How long (seconds) to remember a firing alert fingerprint
# After TTL — next occurrence will trigger a new analysis
ALERT_FINGERPRINT_TTL=86400

# Path to MCP servers config file
MCP_SERVERS_CONFIG_PATH=mcp_servers.yml

# Logging level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# Dry-run / debug mode: log messages instead of sending to Telegram (true/false)
DRY_RUN=false
