# Telegram Bot
# Optional, can be moved to config.yml
TELEGRAM_BOT_TOKEN=your_bot_token_here
# Channel/group ID where Alertmanager sends notifications (negative for groups/channels)
TELEGRAM_CHANNEL_ID=-1001234567890

# SaaS Control Plane
SAAS_AGENT_TOKEN=tok_your_token_here
SAAS_WS_URL=wss://api.srebot.site360.tech/api/v1/agent/connect

# Redis — alert deduplication state
REDIS_URL=redis://redis:6379/0

# Optional variables, can be defined here to override config.yml:
# LLM_RESPONSE_LANGUAGE=English
# ALERT_FINGERPRINT_TTL=86400
# LOG_LEVEL=INFO
# DRY_RUN=false
